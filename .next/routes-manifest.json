{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/applications/[id]",
      "regex": "^/api/applications/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/applications/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/leads/[id]",
      "regex": "^/api/leads/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/leads/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/positions/[id]",
      "regex": "^/api/positions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/positions/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/apply",
      "regex": "^/apply(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/apply(?:/)?$"
    },
    {
      "page": "/careers",
      "regex": "^/careers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/careers(?:/)?$"
    },
    {
      "page": "/portal/applications",
      "regex": "^/portal/applications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/applications(?:/)?$"
    },
    {
      "page": "/portal/leads",
      "regex": "^/portal/leads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/leads(?:/)?$"
    },
    {
      "page": "/portal/login",
      "regex": "^/portal/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/login(?:/)?$"
    },
    {
      "page": "/portal/positions",
      "regex": "^/portal/positions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/positions(?:/)?$"
    },
    {
      "page": "/portal/settings",
      "regex": "^/portal/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/settings(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}